# ─── Midnight ────────────────────────────────────────────────────────────────
# Endpoint WebSocket do Midnight Indexer v3
MIDNIGHT_INDEXER_WS=wss://indexer.testnet.midnight.network/api/v3/graphql/ws

# Endereço do ComplianceRegistry.compact deployado
COMPLIANCE_REGISTRY_ADDRESS=88b021db5e37519a0bd89e828bd0ea98f535e701c480c082566ffc9599d948fc

# Nome do entry point do Compact que registra attestations
ATTESTATION_ENTRY_POINT=register_attestation

# Bloco inicial para ouvir (0 = desde o bloco genesis)
START_FROM_BLOCK=0

# ─── Relayer ──────────────────────────────────────────────────────────────────
# Chave privada EVM do relayer (endereço que vai assinar as TXs)
# Este endereço precisa ter ETH nas chains destino
RELAYER_PRIVATE_KEY=0x...

# Intervalo de reconexão em ms se o WebSocket cair
RECONNECT_INTERVAL_MS=5000

# ─── Base Sepolia ─────────────────────────────────────────────────────────────
BASE_RPC=https://sepolia.base.org
BASE_REGISTRY_ADDRESS=0x278B2B93e74A9E62FE6a29894eE965788Ea48961

# ─── Polkadot Hub Westend ────────────────────────────────────────────────────
POLKADOT_RPC=https://westend-asset-hub-eth-rpc.polkadot.io
POLKADOT_REGISTRY_ADDRESS=0x278B2B93e74A9E62FE6a29894eE965788Ea48961

# ─── Hedera Testnet (adicionar pós WDK) ─────────────────────────────────────
# HEDERA_RPC=https://testnet.hashio.io/api
# HEDERA_REGISTRY_ADDRESS=0x...
